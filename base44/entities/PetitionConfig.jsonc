{
  "name": "PetitionConfig",
  "type": "object",
  "description": "Configura\u00e7\u00f5es globais do gerador de peti\u00e7\u00f5es por IA",
  "properties": {
    "escritorio": {
      "type": "string",
      "description": "Nome do escrit\u00f3rio"
    },
    "advogado_principal": {
      "type": "string",
      "description": "Nome do advogado respons\u00e1vel"
    },
    "oab": {
      "type": "string",
      "description": "N\u00famero OAB"
    },
    "uf_oab": {
      "type": "string",
      "description": "Estado da OAB"
    },
    "email_contato": {
      "type": "string",
      "description": "E-mail do escrit\u00f3rio"
    },
    "telefone": {
      "type": "string",
      "description": "Telefone"
    },
    "cidade_sede": {
      "type": "string",
      "description": "Cidade sede"
    },
    "uf_sede": {
      "type": "string",
      "description": "UF"
    },
    "site": {
      "type": "string",
      "description": "Site do escrit\u00f3rio"
    },
    "logo_url": {
      "type": "string",
      "description": "URL do logotipo/timbre do escrit\u00f3rio"
    },
    "cabecalho_texto": {
      "type": "string",
      "description": "Texto do cabe\u00e7alho do documento (ex: endere\u00e7o, telefone formatados)"
    },
    "rodape_texto": {
      "type": "string",
      "description": "Texto do rodap\u00e9 do documento"
    },
    "papel_timbrado_url": {
      "type": "string",
      "description": "URL de imagem/PDF do papel timbrado completo"
    },
    "modelo_ia": {
      "type": "string",
      "description": "Modelo de IA para gera\u00e7\u00e3o",
      "default": "claude_sonnet_4_6"
    },
    "prompt_sistema": {
      "type": "string",
      "description": "Prompt de sistema para gera\u00e7\u00e3o das peti\u00e7\u00f5es"
    },
    "max_tokens": {
      "type": "number",
      "description": "M\u00e1ximo de tokens por gera\u00e7\u00e3o",
      "default": 4000
    },
    "threshold_confianca": {
      "type": "number",
      "description": "Limiar de confian\u00e7a para sele\u00e7\u00e3o autom\u00e1tica de modelo (0 a 1). Padr\u00e3o: 0.6. Abaixo desse valor, a sele\u00e7\u00e3o \u00e9 encaminhada para revis\u00e3o humana. Quando a regra SINDEEPRES \u00d7 SIEMACO for cadastrada, reduza para 0.4 para incluir porteiros.",
      "default": 0.6
    },
    "ativo": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "escritorio",
    "advogado_principal",
    "oab"
  ]
}