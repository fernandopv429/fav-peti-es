{
  "name": "DefesaConfig",
  "type": "object",
  "description": "Configura\u00e7\u00f5es do gerador de defesas/contesta\u00e7\u00f5es",
  "properties": {
    "escritorio": {
      "type": "string",
      "description": "Nome do escrit\u00f3rio"
    },
    "prompt_sistema": {
      "type": "string",
      "description": "Prompt de sistema para gera\u00e7\u00e3o das defesas"
    },
    "modelo_ia": {
      "type": "string",
      "description": "Modelo de IA",
      "default": "claude_sonnet_4_6"
    },
    "max_tokens": {
      "type": "number",
      "default": 4000
    },
    "ativo": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "escritorio"
  ]
}